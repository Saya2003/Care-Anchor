# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED: AI Model Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Option 1: Use Alibaba Cloud Qwen (Latest Models - RECOMMENDED FOR HACKATHON)
DASHSCOPE_API_KEY="YOUR_ACTUAL_DASHSCOPE_API_KEY_HERE"
QWEN_PLUS_MODEL="qwen2.5-max"
QWEN_MAX_MODEL="qwen2.5-turbo"
EXTRACTION_MODEL="qwen2.5-max"
RESPONSE_MODEL="qwen2.5-turbo"

# Option 2: Use OpenRouter (Backup Configuration)
OPENROUTER_API_KEY="sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
EXTRACTION_MODEL="deepseek/deepseek-v4-flash"
RESPONSE_MODEL="deepseek/deepseek-v4-flash"

# Option 2: Use Alibaba Cloud DashScope (For Hackathon Submission)
# Get your API key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY="YOUR_DASHSCOPE_API_KEY_HERE"
QWEN_API_KEY="YOUR_DASHSCOPE_API_KEY_HERE"
QWEN_PLUS_MODEL="qwen-plus"
QWEN_MAX_MODEL="qwen-max"

