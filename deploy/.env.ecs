# CareAnchor — ECS Production Environment Template
# Copy to .env and fill in your values before deploying.

# ── Alibaba Cloud Model Studio (DashScope) ──────────────────────────
# Get your API key from: https://bailian.console.aliyun.com/
# QWEN_API_KEY is read by alibaba_cloud_config.py (hackathon proof file).
DASHSCOPE_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
QWEN_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
QWEN_PLUS_MODEL="qwen-plus"
QWEN_MAX_MODEL="qwen-max"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# ── PostgreSQL (Docker Compose manages this) ────────────────────────
# The hostname "db" resolves to the PostgreSQL container.
DATABASE_URL="postgresql+asyncpg://postgres:CHANGE_ME@db:5432/careanchor"
POSTGRES_PASSWORD="CHANGE_ME"

# ── Safety alert webhook (optional) ─────────────────────────────────
# If set, the agent POSTs safety threshold breaches here.
ALERT_WEBHOOK_URL=""

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to access the API.
# Include your ECS public IP or domain name.
CORS_ORIGINS="http://localhost:5173,http://localhost,http://<your-ecs-public-ip>"

# ── Safety thresholds ───────────────────────────────────────────────
SYSTOLIC_BP_MAX=180
HEART_RATE_MAX=140
HEART_RATE_MIN=40
SP_O2_MIN=90
TEMPERATURE_MAX=39.5
